network:
  version: 2
  renderer: networkd
  ethernets:
    eth0:
      addresses:
        - {{ mgmt_ip }}/24
      routes:
        - to: default
          via: 10.2.255.254
          metric: 100
    eth1: {}
    eth2: {}
  bonds:
    bond0:
      interfaces: [eth1, eth2]
      parameters:
        mode: 802.3ad
        mii-monitor-interval: 100
        lacp-rate: fast
        transmit-hash-policy: layer3+4
  vlans:
    bond0.101:
      id: 101
      link: bond0
      addresses:
        - {{ vlan101_ip }}/24
      routes:
        - to: 10.1.10.0/24
          via: 192.168.101.1
        - to: 10.1.20.0/24
          via: 192.168.101.1
    bond0.102:
      id: 102
      link: bond0
      addresses:
        - {{ vlan102_ip }}/24
      routes:
        - to: 10.1.30.0/24
          via: 192.168.102.1
